{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "linuxdo-topic-*"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://linux.do/*"
        },
        {
          "url": "https://*.linux.do/*"
        }
      ]
    },
    "store:default"
  ]
}
